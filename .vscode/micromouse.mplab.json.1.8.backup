{
    "version": "1.8",
    "configurations": [
        {
            "name": "default",
            "id": "conf1",
            "device": "dsPIC33FJ128MC802",
            "imagePath": "./out/micromouse/default.elf",
            "packs": [
                {
                    "name": "dsPIC33F-GP-MC_DFP",
                    "vendor": "Microchip",
                    "version": "1.4.235"
                }
            ],
            "fileSet": "default",
            "toolchain": "default-XC16"
        }
    ],
    "propertyGroups": [
        {
            "name": "default-XC16",
            "type": "toolchain",
            "provider": "microchip.toolchains:xc16@2.10",
            "properties": {}
        }
    ],
    "fileSets": [
        {
            "name": "default",
            "files": [
                {
                    "include": "**/*",
                    "exclude": "**/(_build|out|cmake|.vscode)/**/*"
                }
            ]
        }
    ]
}
